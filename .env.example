# Copy this file to `.env.local` and fill in your real values.
# Next.js loads `.env.local` automatically — it does NOT load `.env.example`.

# Resend API key: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sender (use onboarding@resend.dev for testing, or your verified domain for production)
RESEND_FROM_EMAIL=Perfect Love Wedding <onboarding@resend.dev>

# IMPORTANT:
# - Do NOT prefix secrets with NEXT_PUBLIC_ (that exposes them in the browser).
# - On Netlify, set RESEND_API_KEY and RESEND_FROM_EMAIL in Site settings → Environment variables.
# - With onboarding@resend.dev, Resend only delivers to the email on your Resend account (test mode).
